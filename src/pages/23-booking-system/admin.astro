---
// src/pages/23-booking-system/admin.astro
export const prerender = false // Wajib SSR untuk data kasir real-time

import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../utils/supabase'

// 1. Ambil data booking yang VALID / SUDAH LUNAS saja untuk kasir
const { data: allBookings, error } = await supabase
  .from('meetings_booking')
  .select('*')
  .eq('status', 'paid') // 👈 HANYA TAMPILKAN YANG PAID
  .order('created_at', { ascending: false })

// 2. Hitung total omset dummy (Flat Rp 150.000 per slot terisi)
const totalRevenue = (allBookings?.length || 0) * 150000
---

<Layout title="23. Admin Master-List Dashboard">
  <main
    class="bg-slate-955 mx-auto max-w-6xl px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER -->
    <header
      class="mb-8 flex flex-col items-start justify-between gap-4 border-b border-slate-800 pb-6 sm:flex-row sm:items-center"
    >
      <div>
        <div class="mb-2 flex items-center gap-3">
          <span
            class="rounded-md border border-purple-500/30 bg-purple-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-purple-400"
          >
            INTERNAL ADMIN MANAGEMENT
          </span>
          <h1 class="text-2xl font-bold tracking-tight text-white">
            Kasir & Ruangan Dashboard
          </h1>
        </div>
        <p class="text-sm leading-relaxed text-slate-400">
          Rekap total transaksi sewa ruangan masuk via QR Code.
        </p>
      </div>

      <!-- REKAP KOTAK OMSET -->
      <div
        class="min-w-50 rounded-2xl border border-slate-800 bg-slate-900 p-4 font-mono"
      >
        <div class="mb-1 text-[10px] font-bold text-slate-500 uppercase">
          💰 Estimasi Omset:
        </div>
        <div class="text-xl font-black text-amber-400">
          Rp {totalRevenue.toLocaleString('id-ID')}
        </div>
        <div class="mt-0.5 text-[9px] text-slate-400">
          Total Slot: {allBookings?.length || 0} Terpesan
        </div>
      </div>
    </header>

    <!-- TABEL DATA MASTER -->
    <section
      class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900 shadow-xl"
    >
      <div class="border-b border-slate-800 bg-slate-900/50 p-4">
        <h2
          class="font-mono text-xs font-bold tracking-wider text-slate-400 uppercase"
        >
          📋 Log Master Antrean Booking
        </h2>
      </div>

      <div class="overflow-x-auto font-mono text-xs">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr
              class="border-b border-slate-800 bg-slate-950 font-bold text-slate-400"
            >
              <th class="p-4">ID</th>
              <th class="p-4">Pemesan</th>
              <th class="p-4">Kontak</th>
              <th class="p-4">Ruangan</th>
              <th class="p-4">Tanggal Sewa</th>
              <th class="p-4">Slot</th>
            </tr>
          </thead>
          <tbody class="divide-slate-850 divide-y">
            {
              allBookings && allBookings.length > 0 ? (
                allBookings.map((b) => (
                  <tr class="text-slate-300 transition-colors hover:bg-slate-950/40">
                    <td class="p-4 font-bold text-slate-500">#{b.id}</td>
                    <td class="p-4">
                      <div class="font-bold text-white">{b.booker_name}</div>
                    </td>
                    <td class="space-y-0.5 p-4 text-[11px]">
                      <div class="text-slate-400">{b.booker_email}</div>
                      <div class="font-bold text-emerald-400">
                        {b.booker_whatsapp}
                      </div>
                    </td>
                    <td class="p-4">
                      <span class="rounded border border-slate-800 bg-slate-950 px-2 py-0.5 font-bold text-slate-200">
                        {b.room_name}
                      </span>
                    </td>
                    <td class="p-4 font-bold text-white">{b.booking_date}</td>
                    <td class="p-4">
                      <span class="rounded border border-purple-500/20 bg-purple-500/10 px-2 py-0.5 text-[10px] font-bold text-purple-400">
                        {b.time_slot}
                      </span>
                    </td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td
                    colspan="6"
                    class="p-8 text-center font-medium text-slate-500"
                  >
                    📭 Belum ada data booking yang masuk untuk saat ini.
                  </td>
                </tr>
              )
            }
          </tbody>
        </table>
      </div>
    </section>

    <footer class="mt-12 flex justify-between border-t border-slate-900 pt-6">
      <a
        href="/23-booking-system"
        class="font-mono text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Ke Halaman Form User
      </a>
      <a
        href="/"
        class="font-mono text-xs text-slate-500 transition-colors hover:text-white"
      >
        Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>
