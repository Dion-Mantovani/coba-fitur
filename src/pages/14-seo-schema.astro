---
// src/pages/15-seo-faq.astro
import Layout from '../layouts/Layout.astro' // Sesuaikan path layout lo

// 1. DATA MASTER FAQ (Satu data untuk Visual & SEO Dapur Belakang)
const faqData = [
  {
    question: 'Apakah Studion Site mendukung optimasi SEO secara otomatis?',
    answer:
      'Ya, betul sekali! Karena arsitektur Studion berbasis Astro, seluruh halaman dirender menjadi HTML statis murni secara bawaan sehingga performa loading super cepat dan sangat ramah terhadap perayapan (crawling) robot Google.',
  },
  {
    question: 'Bagaimana cara kerja inject FAQ Schema di halaman ini?',
    answer:
      'Sistem backend Astro mengambil data array FAQ, memformatnya menjadi skema standar Schema.org berbasis JSON-LD, lalu menyuntikkannya ke tag head halaman tanpa menambah beban eksekusi JavaScript di sisi browser client.',
  },
  {
    question: 'Apakah saya bisa menggunakan template ini secara gratis?',
    answer:
      'Tentu saja! Sandbox Blueprint UI ini dirancang khusus untuk dokumentasi internal, sarana belajar produksi, dan aset siap pakai (ready-to-use) untuk proyek-proyek agensi atau personal web lo, bro.',
  },
]

// 2. FORMULASI JSON-LD STRUCTURED DATA (PROSES DAPUR BELAKANG)
const jsonLdSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}

// Ubah objek menjadi string mentah agar siap dicetak di HTML
const schemaString = JSON.stringify(jsonLdSchema)

// String tiruan untuk boks salin kode universal (anti-bug Astro compiler)
const codeSnippet = `<script type="application/ld+json">
  ${schemaString}
</script>

<div x-data="{ activeIndex: null }" class="w-full max-w-2xl mx-auto space-y-3 font-sans">
  <div class="border border-slate-800 bg-slate-900 rounded-xl overflow-hidden">
    <button
      @click="activeIndex = (activeIndex === 0 ? null : 0)"
      class="w-full p-5 text-left flex items-center justify-between text-white font-semibold text-sm transition-colors hover:bg-slate-800/40"
    >
      <span>Pertanyaan FAQ 01?</span>
      <i class="fa-solid fa-chevron-down text-xs transition-transform duration-300" :class="activeIndex === 0 ? 'rotate-180 text-amber-400' : 'text-slate-500'"></i>
    </button>
    <div
      x-show="activeIndex === 0"
      x-collapse
      class="border-t border-slate-800/60 bg-slate-950/40 p-5 text-xs text-slate-400 leading-relaxed"
    >
      Isi Jawaban FAQ yang ramah mesin pencari Google.
    </div>
  </div>
</div>`
---

<Layout title="15. SEO & FAQ Schema - Blueprint UI">
  <head>
    <script type="application/ld+json" set:html={schemaString} />
  </head>

  <main
    class="bg-slate-955 mx-auto max-w-4xl px-4 py-12 font-sans text-slate-100"
  >
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-amber-500/30 bg-amber-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-amber-400"
          >15. MENENGAH</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          SEO & FAQ Structured Data Schema
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Komponen integrasi optimasi mesin pencari (*Search Engine
        Optimization*). Menggabungkan komponen visual interaktif akordeon dengan
        injeksi skema metadata <code class="font-mono text-amber-400"
          >application/ld+json</code
        > otomatis.
      </p>
    </header>

    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Preview (Visual Front-End)
      </h2>

      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-inner"
      >
        <div
          x-data="{ activeIndex: null }"
          class="mx-auto w-full max-w-xl space-y-3"
        >
          {
            faqData.map((item, index) => (
              <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900 transition-all duration-300">
                <button
                  x-on:click={`activeIndex = (activeIndex === ${index} ? null : ${index})`}
                  class="flex w-full items-center justify-between p-4 text-left text-xs font-bold text-white transition-colors hover:bg-slate-800/30 focus:outline-none sm:p-5 sm:text-sm"
                >
                  <span
                    x-bind:class={`activeIndex === ${index} ? 'text-amber-400' : 'text-white'`}
                    class="transition-colors"
                  >
                    {item.question}
                  </span>
                  <i
                    class="fa-solid fa-chevron-down text-[10px] transition-transform duration-300"
                    x-bind:class={`activeIndex === ${index} ? 'rotate-180 text-amber-400' : 'text-slate-500'`}
                  />
                </button>

                <div
                  x-show={`activeIndex === ${index}`}
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0 transform -translate-y-2"
                  x-transition:enter-end="opacity-100 transform translate-y-0"
                  class="border-t border-slate-800/60 bg-slate-950/40 p-4 text-xs leading-relaxed text-slate-400 sm:p-5"
                  x-cloak
                >
                  {item.answer}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="seo-title">
      <h2
        id="seo-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Isi Dapur Belakang (Skema JSON-LD yang Terbaca Google Bot)
      </h2>
      <div
        class="max-w-full overflow-x-auto rounded-2xl border border-slate-800 bg-slate-950/80 p-5 font-mono text-[11px] leading-relaxed text-emerald-400"
      >
        <pre><code>{JSON.stringify(jsonLdSchema, null, 2)}</code></pre>
      </div>
    </section>

    <section aria-labelledby="doc-title">
      <h2
        id="doc-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Dokumentasi & Panduan Basic SEO
      </h2>
      <article
        class="space-y-6 rounded-2xl border border-slate-800/60 bg-slate-900/50 p-6 text-xs leading-relaxed text-slate-400 md:text-sm"
      >
        <div>
          <h3 class="mb-2 text-sm font-bold text-slate-200">
            1. Injeksi Otomatis Skema JSON-LD
          </h3>
          <p>
            Struktur data disuntikkan menggunakan properti bawaan Astro <code
              class="font-mono text-yellow-400"
              >set:html=&#123;schemaString&#125;</code
            > langsung di dalam tag head. Strategi ini memastikan bot pencari seperti
            Googlebot langsung membaca metadata tanpa mengalami penundaan eksekusi
            (*rendering-blocker*) yang sering terjadi pada framework berbasis SPA
            (Single Page Application).
          </p>
        </div>

        <div class="border-t border-slate-800/60 pt-4">
          <h3 class="mb-2 text-sm font-bold text-slate-200">
            2. Checklist Meta Tag Wajib (Astro Head)
          </h3>
          <p class="mb-3">
            Untuk hasil maksimal di halaman pencarian Google, pastikan komponen
            layout utama lo minimal menyertakan susunan standar tag berikut ini,
            bro:
          </p>
          <pre
            class="space-y-1 overflow-x-auto rounded-xl bg-slate-950/60 p-4 font-mono text-[11px] text-slate-300">
&lt;!-- Meta Standar --&gt;
&lt;meta charset="UTF-8" /&gt;
&lt;meta name="viewport" content="width=device-width, initial-scale=1.0" /&gt;
&lt;title&gt;Nama Project - Tagline Menarik Maksimal 60 Karakter&lt;/title&gt;
&lt;meta name="description" content="Deskripsi singkat landing page lo yang persuasif, mengandung kata kunci utama, dan idealnya berada di kisaran 150-160 karakter." /&gt;
&lt;meta name="robots" content="index, follow" /&gt;

&lt;!-- Open Graph / Facebook (Biar preview link di WhatsApp/Telegram mewah) --&gt;
&lt;meta property="og:type" content="website" /&gt;
&lt;meta property="og:title" content="Judul Keren Landing Page Lo" /&gt;
&lt;meta property="og:description" content="Deskripsi ringkas pemicu klik saat link dibagikan." /&gt;
&lt;meta property="og:image" content="https://domainlo.com/assets/og-image.png" /&gt;

&lt;!-- Twitter / X Card --&gt;
&lt;meta name="twitter:card" content="summary_large_image" /&gt;
&lt;meta name="twitter:title" content="Judul Keren Landing Page Lo" /&gt;
&lt;meta name="twitter:description" content="Deskripsi ringkas pemicu klik saat link dibagikan." /&gt;
&lt;meta name="twitter:image" content="https://domainlo.com/assets/og-image.png" /&gt;
          </pre>
        </div>

        <div class="border-t border-slate-800/60 pt-4">
          <h3 class="mb-2 text-sm font-bold text-slate-200">
            3. Validasi Keamanan Kode Teks
          </h3>
          <p>
            Semua sintaks kurung kurawal di dalam teks penjelasan dokumentasi
            ini telah dikonversi penuh menggunakan entitas kode HTML terisolasi
            (<code class="font-mono text-amber-400">&amp;#123;</code> dan <code
              class="font-mono text-amber-400">&amp;#125;</code
            >). Hal ini menjamin siklus kompilasi Astro tetap aman tanpa risiko
            kebocoran logika ataupun bentrokan parsing token JavaScript.
          </p>
        </div>
      </article>
    </section>

    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,
      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
