---
// src/pages/08-number-counter.astro
import Layout from '../layouts/Layout.astro' // Sesuaikan path layout lo

// Simpan kodingan produksi universal ke string (Udah pake logika Ease-Out Murni)
const codeSnippet = `<!-- Komponen Number Counter dengan Efek Ease-Out (Murni Alpine.js) -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-4xl mx-auto">

  <!-- Counter 1: Angka Ribuan -->
  <div
    x-data="{ current: 0, target: 1250 }"
    x-init="
      let counter = setInterval(() => {
        // Hitung sisa jarak, lalu bagi dengan pembagi (misal: 10) untuk efek melambat
        let remaining = target - current;
        let step = Math.ceil(remaining / 10);

        current += step;

        if (current >= target) {
          current = target;
          clearInterval(counter);
        }
      }, 16);
    "
    class="bg-slate-900 border border-slate-800 p-6 rounded-2xl text-center"
  >
    <div class="text-3xl font-black text-white tracking-tight mb-1">
      <span x-text="current.toLocaleString('id-ID')"></span>+
    </div>
    <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Active Users</div>
  </div>

  <!-- Counter 2: Angka Persentase -->
  <div
    x-data="{ current: 0, target: 99 }"
    x-init="
      let counter = setInterval(() => {
        let remaining = target - current;
        let step = Math.ceil(remaining / 8); // Pembagi lebih kecil = sedikit lebih agresif

        current += step;

        if (current >= target) {
          current = target;
          clearInterval(counter);
        }
      }, 16);
    "
    class="bg-slate-900 border border-slate-800 p-6 rounded-2xl text-center"
  >
    <div class="text-3xl font-black text-sky-400 tracking-tight mb-1">
      <span x-text="current"></span>%
    </div>
    <div class="text-xs font-medium text-slate-400 uppercase tracking-wider">Satisfaction Rate</div>
  </div>

</div>`
---

<Layout title="08. Number Counter (Ease-Out) - Blueprint UI">
  <main
    class="mx-auto max-w-4xl bg-slate-950 px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER -->
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-sky-400"
          >08. MUDAH</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Number Counter
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Komponen kalkulasi data statistik dengan efek percepatan melambat
        organik (Ease-Out) murni memanfaatkan pembagian sisa jarak dinamis tanpa
        dependensi library eksternal.
      </p>
    </header>

    <!-- SECTION 1: Live Preview Playground -->
    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Preview (Ease-Out Version)
      </h2>

      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-inner"
      >
        <div
          class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-4 sm:grid-cols-3"
        >
          <!-- Box 1 -->
          <div
            x-data="{ current: 0, target: 1250 }"
            x-init="
              let counter = setInterval(() => {
                let remaining = target - current;
                let step = Math.ceil(remaining / 10);
                current += step;
                if (current >= target) { current = target; clearInterval(counter); }
              }, 16);
            "
            class="rounded-xl border border-slate-800 bg-slate-900 p-5 text-center"
          >
            <div class="mb-0.5 text-2xl font-black text-white">
              <span x-text="current.toLocaleString('id-ID')"></span>+
            </div>
            <div
              class="text-[10px] font-bold tracking-wider text-slate-500 uppercase"
            >
              Active Users
            </div>
          </div>

          <!-- Box 2 -->
          <div
            x-data="{ current: 0, target: 99 }"
            x-init="
              let counter = setInterval(() => {
                let remaining = target - current;
                let step = Math.ceil(remaining / 8);
                current += step;
                if (current >= target) { current = target; clearInterval(counter); }
              }, 16);
            "
            class="rounded-xl border border-slate-800 bg-slate-900 p-5 text-center"
          >
            <div class="mb-0.5 text-2xl font-black text-sky-400">
              <span x-text="current"></span>%
            </div>
            <div
              class="text-[10px] font-bold tracking-wider text-slate-500 uppercase"
            >
              Satisfaction
            </div>
          </div>

          <!-- Box 3 -->
          <div
            x-data="{ current: 0, target: 45 }"
            x-init="
              let counter = setInterval(() => {
                let remaining = target - current;
                let step = Math.ceil(remaining / 6);
                current += step;
                if (current >= target) { current = target; clearInterval(counter); }
              }, 16);
            "
            class="rounded-xl border border-slate-800 bg-slate-900 p-5 text-center"
          >
            <div class="mb-0.5 text-2xl font-black text-emerald-400">
              <span x-text="current"></span>+
            </div>
            <div
              class="text-[10px] font-bold tracking-wider text-slate-500 uppercase"
            >
              Blueprints
            </div>
          </div>
        </div>

        <div class="mt-6 text-center">
          <button
            onclick="window.location.reload()"
            class="rounded-lg border border-slate-700/60 bg-slate-800 px-3 py-1.5 text-[10px] font-medium text-slate-300 transition-all hover:bg-slate-700 active:scale-95"
          >
            <i class="fa-solid fa-rotate-right mr-1"></i> Ulangi Animasi Counter
          </button>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Code Snippet Block -->
    <section class="mb-12" aria-labelledby="code-title">
      <h2
        id="code-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Clean Code (Production Ready)
      </h2>
      <article x-data="codeCopier" class="group relative">
        <button
          @click="copy()"
          :class="copied ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-slate-950/60 border-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-900'"
          class="absolute top-3 right-3 z-10 flex items-center gap-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium backdrop-blur-sm transition-all duration-200 active:scale-95"
        >
          <i x-show="!copied" class="fa-regular fa-copy text-sm"></i>
          <i
            x-show="copied"
            class="fa-solid fa-check text-sm text-emerald-400"
            x-cloak></i>
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>
        <pre
          class="h-100 overflow-auto rounded-2xl border border-slate-800 bg-slate-900 p-5 pr-20 font-mono text-xs leading-relaxed text-slate-300"><code>{codeSnippet}</code></pre>
      </article>
    </section>

    <!-- SECTION 3: Dokumentasi & Catatan Teknis -->
    <section aria-labelledby="doc-title">
      <h2
        id="doc-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Dokumentasi Logika
      </h2>
      <article
        class="space-y-4 rounded-2xl border border-slate-800/60 bg-slate-900/50 p-5 text-xs leading-relaxed text-slate-400 md:text-sm"
      >
        <p>
          <strong class="text-slate-200"
            >1. Logika Perubahan Jarak (`remaining / X`):</strong
          > Kita membuang variabel durasi statis dan menggantinya dengan rumusan <code
            class="font-mono text-yellow-400"
            >let step = Math.ceil(remaining / pembagi)</code
          >. Semakin besar angka pembagi yang lo taruh di sana (misal 10), rem
          animasinya bakal terasa semakin pakem dan durasi melambatnya jadi
          sedikit lebih panjang.
        </p>
        <p>
          <strong class="text-slate-200">2. Math.ceil Pengaman Mentok:</strong> Pembulatan
          ke atas wajib dipakai menggunakan fungsi bawaan JavaScript <code
            class="font-mono text-slate-300">Math.ceil()</code
          >. Tujuannya agar saat sisa angka tinggal sedikit (misal sisa 0.4),
          nilainya tidak dibulatkan ke nol yang bisa bikin angkanya macet di
          jalan sebelum menyentuh target pas.
        </p>
      </article>
    </section>

    <!-- Tombol Kembali -->
    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,
      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
