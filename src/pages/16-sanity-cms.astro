---
// src/pages/16-sanity-cms.astro

export const prerender = false

import Layout from '../layouts/Layout.astro' // Sesuaikan path layout lo
import { sanityClient } from '../utils/sanity'

// 1. QUERY GROQ: Mengambil semua dokumen ber-tipe 'tour' dari Sanity Cloud
const tours = await sanityClient.fetch(`*[_type == "tour"]{
  _id,
  name,
  "slug": slug.current,
  price,
  description
}`)

const codeSnippet = `// 1. Cara Fetch Data via GROQ di Astro Backend (src/pages/travel.astro)
import { createClient } from '@sanity/client';

const client = createClient({
  projectId: 'PROJECT_ID_LO',
  dataset: 'production',
  useCdn: true,
  apiVersion: '2024-03-01'
});

const tours = await client.fetch(\`*[_type == "tour"]{ name, price, description }\`);`
---

<Layout title="16. CMS Integration (Sanity) - Blueprint UI">
  <main
    class="bg-slate-955 mx-auto max-w-4xl px-4 py-12 font-sans text-slate-100"
  >
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-rose-500/30 bg-rose-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-rose-400"
          >16. KOMPLEKS</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Headless CMS (Sanity) Integration
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Menghubungkan Astro dengan Headless CMS cloud. Mengambil arsitektur data
        travel secara dinamis menggunakan mesin *query* **GROQ** untuk proses
        render serverless instant.
      </p>
    </header>

    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Data Render From Sanity Cloud
      </h2>

      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-inner"
      >
        {
          tours.length === 0 ? (
            <div class="rounded-xl border border-dashed border-slate-800 bg-slate-950/40 py-8 text-center">
              <p class="text-xs text-slate-500 italic">
                Data kosong, pastikan lo sudah klik Publish data di
                localhost:3333 ya bro...
              </p>
            </div>
          ) : (
            <div class="mx-auto grid max-w-2xl grid-cols-1 gap-4 sm:grid-cols-2">
              {tours.map((tour: any) => (
                <div class="group flex min-h-40 flex-col justify-between rounded-xl border border-slate-800/80 bg-slate-900 p-5 transition-all hover:border-rose-500/40">
                  <div>
                    <div class="flex items-start justify-between gap-2">
                      <h3 class="text-xs leading-snug font-bold text-white transition-colors group-hover:text-rose-400">
                        {tour.name}
                      </h3>
                      <span class="rounded border border-rose-500/20 bg-rose-500/10 px-1.5 py-0.5 font-mono text-[8px] text-rose-400">
                        /{tour.slug}
                      </span>
                    </div>
                    <p class="mt-2 line-clamp-3 text-[11px] leading-relaxed text-slate-400">
                      {tour.description ||
                        'Tidak ada deskripsi singkat yang dimasukkan di dasbor Sanity.'}
                    </p>
                  </div>

                  <div class="mt-4 flex items-center justify-between border-t border-slate-950 pt-3">
                    <span class="text-[10px] text-slate-500">Harga Tiket:</span>
                    <span class="font-mono text-xs font-bold text-emerald-400">
                      Rp {Number(tour.price).toLocaleString('id-ID')}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <section class="mb-12" aria-labelledby="code-title">
      <h2
        id="code-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Clean Code Integration Blueprint
      </h2>
      <article x-data="codeCopier" class="group relative">
        <button
          @click="copy()"
          :class="copied ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-slate-950/60 border-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-900'"
          class="absolute top-3 right-3 z-10 flex items-center gap-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium backdrop-blur-sm transition-all duration-200 active:scale-95"
        >
          <i x-show="!copied" class="fa-regular fa-copy text-sm"></i>
          <i
            x-show="copied"
            class="fa-solid fa-check text-sm text-emerald-400"
            x-cloak></i>
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>
        <pre
          class="h-100 overflow-auto rounded-2xl border border-slate-800 bg-slate-900 p-5 pr-20 font-mono text-xs leading-relaxed text-slate-300"><code>{codeSnippet}</code></pre>
      </article>
    </section>

    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,
      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
