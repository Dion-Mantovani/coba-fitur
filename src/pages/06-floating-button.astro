---
// src/pages/06-floating-button.astro
import Layout from '../layouts/Layout.astro' // Sesuaikan path layout lo

// Simpan kodingan produksi universal ke string (Untuk window utama proyek riil)
const codeSnippet = `<!-- Komponen Floating Action Button (FAB) Universal Proyek Riil -->
<div x-data="{ isOpen: false }" class="fixed bottom-6 right-6 z-50 flex flex-col items-center gap-3">

  <!-- Barisan Menu Aksi Melayang (Muncul vertikal ke atas) -->
  <div
    x-show="isOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-end="opacity-0 translate-y-4 scale-95"
    class="flex flex-col items-center gap-3"
    x-cloak
  >
    <!-- Aksi 1: WhatsApp -->
    <button class="w-10 h-10 rounded-full bg-emerald-600 hover:bg-emerald-500 text-white shadow-md flex items-center justify-center transition-colors group relative">
      <i class="fa-brands fa-whatsapp text-lg"></i>
      <span class="absolute right-full mr-3 px-2 py-1 bg-slate-900 border border-slate-800 text-xs text-slate-300 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">WhatsApp Chat</span>
    </button>

    <!-- Aksi 2: Phone -->
    <button class="w-10 h-10 rounded-full bg-sky-600 hover:bg-sky-500 text-white shadow-md flex items-center justify-center transition-colors group relative">
      <i class="fa-solid fa-phone text-sm"></i>
      <span class="absolute right-full mr-3 px-2 py-1 bg-slate-900 border border-slate-800 text-xs text-slate-300 rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">Hubungi Kami</span>
    </button>
  </div>

  <!-- Tombol Utama FAB (Berputar saat terbuka) -->
  <button
    @click="isOpen = !isOpen"
    @click.away="isOpen = false"
    :class="isOpen ? 'bg-rose-600 hover:bg-rose-500 rotate-135' : 'bg-sky-500 hover:bg-sky-600'"
    class="w-12 h-12 rounded-full text-white shadow-lg flex items-center justify-center transform transition-all duration-300 focus:outline-none active:scale-95"
    aria-label="Toggle floating menu"
  >
    <i class="fa-solid fa-plus text-lg"></i>
  </button>

</div>`
---

<Layout title="06. Floating Action Button - Blueprint UI">
  <main
    class="mx-auto max-w-4xl bg-slate-950 px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER: Judul & Deskripsi Fitur -->
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-sky-400"
          >06. MUDAH</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Floating Action Button (FAB)
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Komponen tombol melayang interaktif penunjang konversi (CTA).
        Memanfaatkan teknik rotasi sumbu transformasi CSS untuk mengubah icon
        pemicu dan transisi koordinat sumbu Y mikro untuk memunculkan anak menu.
      </p>
    </header>

    <!-- SECTION 1: Live Preview Playground -->
    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Preview
      </h2>

      <!-- Container Sandbox Box (Tetap kokoh, FAB dikunci di POJOK KIRI BAWAH internal sandbox) -->
      <div
        class="relative h-75 w-full overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40 shadow-inner"
      >
        <!-- Tulisan Penanda Tengah -->
        <div
          class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-10"
        >
          <span class="font-mono text-xs text-white"
            >[ Area Simulasi Halaman ]</span
          >
        </div>

        <!-- FAB Terisolasi Lokal: Terkunci di pojok kiri bawah kontainer preview -->
        <div
          x-data="{ isOpen: false }"
          class="absolute right-5 bottom-5 z-40 flex flex-col items-center gap-3"
        >
          <!-- Menu Aksi Menu Lokal -->
          <div
            x-show="isOpen"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 translate-y-3 scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 scale-100"
            x-transition:leave="transition ease-in duration-100"
            x-transition:leave-end="opacity-0 translate-y-3 scale-95"
            class="flex flex-col items-center gap-2.5"
            x-cloak
          >
            <!-- WhatsApp -->
            <button
              @click="alert('Membuka WhatsApp...')"
              class="group relative flex h-9 w-9 items-center justify-center rounded-full bg-emerald-600 text-white shadow transition-colors hover:bg-emerald-500"
            >
              <i class="fa-brands fa-whatsapp text-base"></i>
              <span
                class="absolute right-full mr-2 rounded border border-slate-800 bg-slate-950 px-2 py-0.5 text-[10px] whitespace-nowrap text-slate-300 opacity-0 transition-opacity group-hover:opacity-100"
                >CS WhatsApp</span
              >
            </button>

            <!-- Telepon -->
            <button
              @click="alert('Memanggil nomor CS...')"
              class="group relative flex h-9 w-9 items-center justify-center rounded-full bg-indigo-600 text-white shadow transition-colors hover:bg-indigo-500"
            >
              <i class="fa-solid fa-phone text-xs"></i>
              <span
                class="absolute right-full mr-2 rounded border border-slate-800 bg-slate-950 px-2 py-0.5 text-[10px] whitespace-nowrap text-slate-300 opacity-0 transition-opacity group-hover:opacity-100"
                >Hotline</span
              >
            </button>
          </div>

          <!-- Tombol Utama Bulat -->
          <button
            @click="isOpen = !isOpen"
            @click.away="isOpen = false"
            :class="isOpen ? 'bg-rose-600 rotate-135' : 'bg-sky-500'"
            class="flex h-11 w-11 transform items-center justify-center rounded-full text-white shadow-md transition-all duration-300 focus:outline-none active:scale-95"
          >
            <i class="fa-solid fa-plus text-base"></i>
          </button>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Code Snippet Block (Siap Salin) -->
    <section class="mb-12" aria-labelledby="code-title">
      <h2
        id="code-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Clean Code (Production Ready)
      </h2>
      <article x-data="codeCopier" class="group relative">
        <button
          @click="copy()"
          :class="copied ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-slate-950/60 border-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-900'"
          class="absolute top-3 right-3 z-10 flex items-center gap-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium backdrop-blur-sm transition-all duration-200 active:scale-95"
          aria-label="Salin kode"
        >
          <i x-show="!copied" class="fa-regular fa-copy text-sm"></i>
          <i
            x-show="copied"
            class="fa-solid fa-check text-sm text-emerald-400"
            x-cloak></i>
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>

        <!-- Sesuai Standar Mutlak: Menggunakan h-100 dan overflow-auto -->
        <pre
          class="h-100 overflow-auto rounded-2xl border border-slate-800 bg-slate-900 p-5 pr-20 font-mono text-xs leading-relaxed text-slate-300"><code>{codeSnippet}</code></pre>
      </article>
    </section>

    <!-- SECTION 3: Dokumentasi & Catatan Teknis -->
    <section aria-labelledby="doc-title">
      <h2
        id="doc-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Dokumentasi Logika
      </h2>
      <article
        class="space-y-4 rounded-2xl border border-slate-800/60 bg-slate-900/50 p-5 text-xs leading-relaxed text-slate-400 md:text-sm"
      >
        <p>
          <strong class="text-slate-200">1. Efek Rotasi Ikon Plus:</strong> Menambahkan
          kelas binding dinamis <code class="font-mono text-yellow-400"
            >rotate-135</code
          > saat status menu bernilai terbuka. Angka putaran 135 derajat dipilih secara
          matematis agar sudut lengkung silang dari tanda tambah (`+`) bergeser lurus
          membentuk tanda silang pembatalan (`x`) sempurna.
        </p>
        <p>
          <strong class="text-slate-200">2. Tooltip Indikator Aksi:</strong> Setiap
          anak tombol aksi dibekali tag elemen teks bermodifikasi kelas <code
            class="font-mono text-slate-300">group-hover:opacity-100</code
          >. Struktur ini mempermudah kemunculan petunjuk label teks bantuan di
          sebelah kiri/kanan secara instan saat kursor mouse menyentuh tombol
          terkait.
        </p>
      </article>
    </section>

    <!-- Tombol Kembali -->
    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<!-- Script Logic Handler Salin -->
<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,
      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
