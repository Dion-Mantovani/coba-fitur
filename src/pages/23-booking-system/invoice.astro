---
// src/pages/23-booking-system/invoice.astro
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../utils/supabase'

const url = new URL(Astro.request.url)
const bookingId = url.searchParams.get('id')

if (!bookingId) {
  return Astro.redirect('/23-booking-system')
}

// Tarik data detail booking
const { data: booking, error } = await supabase
  .from('meetings_booking')
  .select('*')
  .eq('id', bookingId)
  .single()

if (error || !booking) {
  return Astro.redirect('/23-booking-system')
}

// Cek status kedaluwarsa secara real-time di server
const createdAtTime = new Date(booking.created_at).getTime()
const timeDiff = Date.now() - createdAtTime
const isExpired = booking.status === 'unpaid' && timeDiff >= 60000 // 1 menit = 60000ms

// Handle Aksi Form (Bayar atau Batal)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const action = formData.get('action')

  if (action === 'pay' && !isExpired && booking.status === 'unpaid') {
    // Simulasi Berhasil Bayar: Ubah status jadi 'paid'
    await supabase
      .from('meetings_booking')
      .update({ status: 'paid' })
      .eq('id', bookingId)

    return Astro.redirect(`/23-booking-system/invoice?id=${bookingId}`)
  }

  if (action === 'cancel' || isExpired) {
    // Hapus data booking dari DB karena batal / expired
    await supabase.from('meetings_booking').delete().eq('id', bookingId)

    return Astro.redirect('/23-booking-system')
  }
}

// Hitung sisa detik untuk dioper ke JavaScript Client
const timeLeftSeconds = Math.max(0, Math.floor((60000 - timeDiff) / 1000))

// Membuat kode check-in random unik (Dummy)
const checkInCode = `SR-${booking.id}-${Math.random().toString(36).substring(2, 6).toUpperCase()}`
---

<Layout title="23. Status Pembayaran Sewa">
  <main
    class="bg-slate-955 mx-auto min-h-screen max-w-2xl px-4 py-12 font-sans text-slate-100"
  >
    <div
      class="relative space-y-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-xl md:p-8"
    >
      <div
        class={`absolute top-0 left-0 right-0 h-1.5 ${booking.status === 'paid' ? 'bg-emerald-500' : isExpired ? 'bg-rose-600' : 'bg-amber-500 animate-pulse'}`}
      >
      </div>

      <!-- HEADER STATUS -->
      <div class="space-y-2 text-center">
        {
          booking.status === 'paid' ? (
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 font-mono text-xs font-bold text-emerald-400">
              ✅ LUNAS / PAID
            </div>
          ) : isExpired ? (
            <div class="inline-flex items-center gap-2 rounded-full border border-rose-500/20 bg-rose-500/10 px-3 py-1 font-mono text-xs font-bold text-rose-400">
              ⏰ KEDALUWARSA / EXPIRED
            </div>
          ) : (
            <div class="inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-3 py-1 font-mono text-xs font-bold text-amber-400">
              ⏳ MENUNGGU PEMBAYARAN (
              <span id="countdown">{timeLeftSeconds}s</span>)
            </div>
          )
        }

        <h1 class="text-xl font-extrabold tracking-tight text-white">
          Detail Transaksi Ruangan
        </h1>
        <p class="font-mono text-xs text-slate-500">
          ID Transaksi: #{booking.id}
        </p>
      </div>

      <!-- KONDISI SUDAH BAYAR (TAMPILKAN KODE CHECK-IN) -->
      {
        booking.status === 'paid' && (
          <div class="bg-emerald-550/10 space-y-3 rounded-xl border border-emerald-500/30 p-5 text-center font-mono">
            <div class="text-[10px] font-bold tracking-wider text-emerald-400 uppercase">
              🔑 KODE MASUK / CHECK-IN RUANGAN:
            </div>
            <div class="border-slate-850 rounded-lg border bg-slate-950/60 py-2.5 text-2xl font-black tracking-widest text-white">
              {checkInCode}
            </div>
            <p class="text-[10px] leading-relaxed text-slate-400">
              *Simpan baik-baik kode di atas bro. Tunjukkan ke tab sensor pintu
              digital atau resepsionis saat mau masuk ruangan nanti!
            </p>
          </div>
        )
      }

      <!-- KONDISI TIMEOUT EXPIRED -->
      {
        isExpired && (
          <div class="bg-rose-550/10 rounded-xl border border-rose-500/30 p-4 text-center font-mono text-xs text-rose-400">
            Waktu pembayaran lo udah habis lebih dari 1 menit, bro. Slot ruangan
            otomatis dilepas kembali ke publik!
          </div>
        )
      }

      <!-- DETAIL TRANSAKSI -->
      <div
        class="space-y-3 border-t border-b border-slate-800 py-4 font-mono text-xs"
      >
        <div class="flex justify-between">
          <span class="text-slate-400">Nama Pemesan:</span><span
            class="font-bold text-white">{booking.booker_name}</span
          >
        </div>
        <div class="flex justify-between">
          <span class="text-slate-400">Ruangan:</span><span
            class="font-bold text-emerald-400">{booking.room_name}</span
          >
        </div>
        <div class="flex justify-between">
          <span class="text-slate-400">Tanggal & Slot:</span><span
            class="font-bold text-white"
            >{booking.booking_date} ({booking.time_slot})</span
          >
        </div>
        <div class="flex justify-between text-sm">
          <span class="font-bold text-slate-300">Total Tagihan:</span><span
            class="font-black text-amber-400">Rp 150.000</span
          >
        </div>
      </div>

      <!-- TOMBOL AKSI INTERAKTIF -->
      <div class="space-y-3 pt-2">
        {
          booking.status === 'unpaid' && !isExpired && (
            <>
              <form method="POST">
                <input type="hidden" name="action" value="pay" />
                <button
                  type="submit"
                  class="w-full cursor-pointer rounded-xl bg-emerald-600 px-4 py-3 text-center font-sans text-sm font-bold text-white shadow-lg shadow-emerald-900/20 transition-colors hover:bg-emerald-700"
                >
                  💵 BAYAR SEKARANG (Simulasi)
                </button>
              </form>

              <form method="POST">
                <input type="hidden" name="action" value="cancel" />
                <button
                  type="submit"
                  onclick="return confirm('Beneran mau dibatalin?')"
                  class="w-full cursor-pointer rounded-xl border border-slate-800 bg-slate-950 px-4 py-2 font-mono text-xs text-slate-400 transition-all hover:border-rose-500/40 hover:text-rose-400"
                >
                  ❌ Batalkan Pemesanan
                </button>
              </form>
            </>
          )
        }

        {
          (booking.status === 'paid' || isExpired) && (
            <a
              href="/23-booking-system"
              class="block w-full rounded-xl bg-slate-800 px-4 py-3 text-center font-sans text-sm font-bold text-white transition-colors hover:bg-slate-700"
            >
              Kembali ke Halaman Utama
            </a>
          )
        }
      </div>
    </div>
  </main>
</Layout>

<!-- JAVASCRIPT CLIENT FOR REAL-TIME COUNTDOWN DOWNGRADE -->
<script define:vars={{ timeLeftSeconds }}>
  let time = timeLeftSeconds
  const countdownEl = document.getElementById('countdown')

  if (countdownEl && time > 0) {
    const timer = setInterval(() => {
      time--
      if (countdownEl) countdownEl.innerText = time + 's'

      if (time <= 0) {
        clearInterval(timer)
        // Otomatis reload halaman agar server Astro mengeksekusi penghapusan/pembatalan karena timeout
        window.location.reload()
      }
    }, 1000)
  }
</script>
