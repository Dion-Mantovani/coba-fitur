---
// src/pages/15-astro-api/index.astro
import Layout from '../../layouts/Layout.astro'

// Simpan kodingan produksi backend universal ke string agar siap disalin penuh
const codeSnippet = `// 1. FILE ENDPOINT SERVER: src/pages/api/travel.json.ts
import type { APIRoute } from 'astro';

export const GET: APIRoute = async ({ request }) => {
  const mockData = [
    { id: 1, destination: "Kyoto, Jepang", price: 15500000 },
    { id: 2, destination: "Raja Ampat, Indonesia", price: 8900000 }
  ];

  return new Response(
    JSON.stringify({ success: true, timestamp: new Date().toISOString(), data: mockData }),
    {
      status: 200,
      headers: {
        'Content-Type': 'application/json',
        'Cache-Control': 'public, max-age=3600',
        'Access-Control-Allow-Origin': '*' // Mengizinkan cross-origin request aman
      }
    }
  );
};

// 2. FILE KONTROL FRONT-END (MURNI ALPINE.JS CONSUMER)
/*
<div x-data="{
  apiData: null,
  async fetchApi() {
    const res = await fetch('/api/travel.json');
    this.apiData = await res.json();
  }
}">
  <button @click="fetchApi()">Tembak Server</button>
  <pre><code x-text="JSON.stringify(apiData, null, 2)"></code></pre>
</div>
*/`
---

<Layout title="15. Astro API Endpoints - Blueprint UI">
  <main
    class="bg-slate-955 mx-auto max-w-4xl px-4 py-12 font-sans text-slate-100"
  >
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-rose-500/30 bg-rose-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-rose-400"
          >15. KOMPLEKS</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Native API Endpoints
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Gerbang pembuka logika backend. Membuat fungsi rute server (*serverless
        function route*) berbasis TypeScript untuk menyajikan rest data JSON
        tanpa overhead framework luar.
      </p>
    </header>

    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Preview API Simulator
      </h2>

      <div
        class="space-y-4 rounded-2xl border border-slate-800 bg-slate-900/40 p-6 shadow-inner"
      >
        <div
          x-data="{
            apiData: null,
            isLoading: false,
            async hitEndpoint() {
              this.isLoading = true;
              try {
                const res = await fetch('/15-astro-api/data.json');
                this.apiData = await res.json();
              } catch (err) {
                alert('Gagal mengambil data API');
              } finally {
                this.isLoading = false;
              }
            }
          }"
          class="mx-auto max-w-xl space-y-4"
        >
          <div
            class="flex items-center justify-between rounded-xl border border-slate-800 bg-slate-950 p-3"
          >
            <div class="flex items-center gap-2">
              <span
                class="rounded-md border border-emerald-500/30 bg-emerald-500/20 px-2 py-0.5 font-mono text-[10px] font-bold text-emerald-400"
                >GET</span
              >
              <code class="text-xs text-slate-300">/15-astro-api/data.json</code
              >
            </div>
            <button
              @click="hitEndpoint()"
              class="flex items-center gap-1.5 rounded-lg bg-rose-600 px-4 py-1.5 text-[11px] font-bold text-white shadow-lg shadow-rose-600/10 transition-all hover:bg-rose-500 active:scale-95"
            >
              <i
                x-show="isLoading"
                class="fa-solid fa-spinner animate-spin"
                x-cloak></i>
              Tembak API
            </button>
          </div>

          <div
            class="relative max-h-60 min-h-30 overflow-y-auto rounded-xl border border-slate-800 bg-slate-950 p-4 font-mono text-[11px] text-slate-400"
          >
            <span
              class="absolute top-2 right-3 font-sans text-[9px] tracking-wider text-slate-600 uppercase"
              >JSON Response Body</span
            >

            <template x-if="!apiData && !isLoading">
              <p class="text-slate-600 italic">
                Klik tombol "Tembak API" untuk melihat siklus data backend...
              </p>
            </template>
            <template x-if="isLoading">
              <p class="animate-pulse text-rose-400">
                Menghubungkan ke Astro Server Engine...
              </p>
            </template>
            <template x-if="apiData">
              <pre
                class="text-emerald-400"><code x-text="JSON.stringify(apiData, null, 2)" /></pre>
            </template>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="code-title">
      <h2
        id="code-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Clean Code (Server Endpoint Template)
      </h2>
      <article x-data="codeCopier" class="group relative">
        <button
          @click="copy()"
          :class="copied ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-slate-950/60 border-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-900'"
          class="absolute top-3 right-3 z-10 flex items-center gap-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium backdrop-blur-sm transition-all duration-200 active:scale-95"
        >
          <i x-show="!copied" class="fa-regular fa-copy text-sm"></i>
          <i
            x-show="copied"
            class="fa-solid fa-check text-sm text-emerald-400"
            x-cloak></i>
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>
        <pre
          class="h-100 overflow-auto rounded-2xl border border-slate-800 bg-slate-900 p-5 pr-20 font-mono text-xs leading-relaxed text-slate-300"><code>{codeSnippet}</code></pre>
      </article>
    </section>

    <section aria-labelledby="doc-title">
      <h2
        id="doc-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Dokumentasi Logika Backend
      </h2>
      <article
        class="space-y-4 rounded-2xl border border-slate-800/60 bg-slate-900/50 p-5 text-xs leading-relaxed text-slate-400 md:text-sm"
      >
        <p>
          <strong class="text-slate-200"
            >1. Konsep File Routing `.json.ts`:</strong
          > Berbeda dengan rute visual, penulisan ekstensi file ganda seperti <code
            class="font-mono text-yellow-400">data.json.ts</code
          > di dalam folder halaman memaksa sistem internal build Astro mengompilasi
          rutenya langsung menjadi rute data statis atau serverless API murni ber-output
          JSON, bukan dokumen HTML.
        </p>
        <p>
          <strong class="text-slate-200"
            >2. Keamanan Kebijakan CORS & Cache:</strong
          > Pemasangan header <code class="font-mono text-slate-300"
            >Access-Control-Allow-Origin: '*'</code
          > menjamin API buatan lo bisa diakses secara aman lintas domain, sementara
          injeksi <code class="font-mono text-slate-300">Cache-Control</code> menghemat
          utilisasi hit CPU server dengan menyimpan cache respons di sisi client selama
          rentang waktu yang ditentukan.
        </p>
      </article>
    </section>

    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,
      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
