---
// src/pages/01-sticky-header.astro
import Layout from '../layouts/Layout.astro' // Sesuaikan path layout lo

// Simpan kodingan ke dalam string agar aman tidak dieksekusi browser
const codeSnippet = `
<header
  x-data="{ isScrolled: false }"
  @scroll.window="isScrolled = (window.pageYOffset > 50)"
  :class="isScrolled ? 'bg-slate-900/90 border-slate-800 py-3 backdrop-blur-md shadow-lg' : 'bg-transparent border-transparent py-5'"
  class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-300 ease-in-out"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
    <div class="font-bold text-xl text-white">Logo</div>
    <nav class="hidden md:flex items-center gap-8 text-sm text-slate-300">
      <a href="#" class="hover:text-white">Home</a>
      <a href="#" class="hover:text-white">About</a>
    </nav>
  </div>
</header>`
---

<Layout title="01. Sticky Header - Blueprint UI">
  <main
    class="mx-auto max-w-4xl bg-slate-950 px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER: Judul & Deskripsi Fitur -->
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-sky-400"
          >01. MUDAH</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Sticky Header
        </h1>
      </div>
      <p class="text-sm text-slate-400">
        Komponen navigasi atas pintar yang mendeteksi posisi scroll untuk
        mengubah ukuran, warna latar belakang, dan efek bayangan secara dinamis
        demi menjaga kenyamanan navigasi user.
      </p>
    </header>

    <!-- SECTION 1: Live Preview Playground -->
    <section class="mb-12" aria-labelledby="preview-title">
      <h2
        id="preview-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Live Preview
      </h2>

      <!-- Container Utama Layar Simulasi (Kita pasang x-data di sini biar dia dengerin scroll containernya sendiri) -->
      <div
        x-data="{ isScrolled: false }"
        @scroll="isScrolled = ($el.scrollTop > 15)"
        class="relative h-87.5 w-full overflow-y-auto rounded-2xl border border-slate-800 bg-slate-900 shadow-inner"
      >
        <!-- KOMPONEN UTAMA: Sticky Header (Membaca state isScrolled dari parent container) -->
        <header
          :class="isScrolled ? 'bg-slate-950/90 border-slate-800 py-3 backdrop-blur-md shadow-md' : 'bg-transparent border-transparent py-5'"
          class="sticky top-0 right-0 left-0 z-40 flex items-center justify-between border-b px-6 transition-all duration-300 ease-in-out"
        >
          <!-- Logo -->
          <div class="text-sm font-bold tracking-tight text-white">
            Core<span class="text-sky-400">Lab</span>
          </div>
          <!-- Menu Navigasi -->
          <nav
            class="flex items-center gap-4 text-xs font-medium text-slate-400"
          >
            <span class="text-white">Home</span>
            <span>Features</span>
            <span>Pricing</span>
          </nav>
        </header>

        <!-- Dummy Content Internal Container (Dibuat super panjang ke bawah agar puas scroll-nya) -->
        <div class="space-y-8 px-6 pt-12 pb-40 text-center">
          <div class="py-4">
            <p class="mb-2 font-mono text-xs text-slate-500">
              [ Mulai scroll kotak ini ke bawah ]
            </p>
            <div
              class="mx-auto flex h-10 w-10 animate-bounce items-center justify-center rounded-full border border-slate-800 text-slate-400"
            >
              ↓
            </div>
          </div>

          <!-- Baris Konten Ganjalan Masif -->
          <div class="mx-auto max-w-md space-y-4 text-left opacity-30">
            <div class="h-4 w-3/4 rounded bg-slate-800"></div>
            <div class="h-4 rounded bg-slate-800"></div>
            <div class="h-4 w-5/6 rounded bg-slate-800"></div>
            <p class="font-mono text-xs text-slate-500">
              Scroll terus kebawah untuk melihat transisi mengecil...
            </p>
            <div class="h-4 w-2/3 rounded bg-slate-800"></div>
            <div class="h-4 rounded bg-slate-800"></div>
            <div class="h-4 w-1/2 rounded bg-slate-800"></div>
            <div class="h-4 rounded bg-slate-800"></div>
            <div class="h-4 w-5/6 rounded bg-slate-800"></div>
            <div class="h-4 w-3/4 rounded bg-slate-800"></div>
            <div class="h-4 rounded bg-slate-800"></div>
            <p class="font-mono text-xs text-slate-500">
              Header di atas otomatis mengecil & memadat.
            </p>
            <div class="h-4 w-2/3 rounded bg-slate-800"></div>
            <div class="h-4 rounded bg-slate-800"></div>
            <div class="h-4 w-3/4 rounded bg-slate-800"></div>
            <div class="h-4 w-1/2 rounded bg-slate-800"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: Code Snippet Block (Siap Salin untuk Proyek Riil) -->
    <section class="mb-12" aria-labelledby="code-title">
      <h2
        id="code-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Clean Code (Production Ready)
      </h2>

      <!-- Panggil logic dengan nama codeCopier yang sudah didaftarkan di script bawah -->
      <article x-data="codeCopier" class="group relative">
        <!-- Tombol Salin Melayang Font Awesome -->
        <button
          @click="copy()"
          :class="copied ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-slate-950/60 border-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-900'"
          class="absolute top-3 right-3 z-10 flex items-center gap-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium backdrop-blur-sm transition-all duration-200 active:scale-95"
          aria-label="Salin kode"
        >
          <!-- Ikon Kertas (Copy) - Otomatis sembunyi kalau copied = true -->
          <i x-show="!copied" class="fa-regular fa-copy text-sm"></i>

          <!-- Ikon Centang (Success) - Otomatis muncul kalau copied = true -->
          <i
            x-show="copied"
            class="fa-solid fa-check text-sm text-emerald-400"
            x-cloak></i>

          <!-- Teks Status -->
          <span x-text="copied ? 'Copied!' : 'Copy'"></span>
        </button>

        <!-- Render text dari variabel codeSnippet -->
        <pre
          class="h-100 overflow-auto rounded-2xl border border-slate-800 bg-slate-900 p-5 pr-20 font-mono text-xs leading-relaxed text-slate-300"><code>{codeSnippet}</code></pre>
      </article>
    </section>

    <!-- SECTION 3: Dokumentasi & Catatan Teknis -->
    <section aria-labelledby="doc-title">
      <h2
        id="doc-title"
        class="mb-3 text-sm font-semibold tracking-wider text-slate-400 uppercase"
      >
        Dokumentasi Logika
      </h2>
      <article
        class="space-y-4 rounded-2xl border border-slate-800/60 bg-slate-900/50 p-5 text-xs leading-relaxed text-slate-400 md:text-sm"
      >
        <p>
          <strong class="text-slate-200">1. Reaktivitas Alpine.js:</strong> Directive
          <code class="font-mono text-yellow-400">x-data</code> menginisiasi status
          Boolean awal <code class="font-mono text-slate-300"
            >isScrolled: false</code
          >. Saat layar di-scroll melewati ambang batas piksel tertentu,
          ekspresi mengubah status menjadi <code
            class="font-mono text-slate-300">true</code
          >.
        </p>
        <p>
          <strong class="text-slate-200">2. Pengikatan Class Dinamis:</strong> Syntax
          <code class="font-mono text-yellow-400">:class</code> (singkatan dari <code
            class="font-mono text-slate-300">x-bind:class</code
          >) akan mengevaluasi kondisi variabel tersebut. Jika aktif, modifier
          Tailwind v4 seperti penurunan padding (<code
            class="font-mono text-slate-300">py-3</code
          >) dan pengaktifan filter kaca (<code class="font-mono text-slate-300"
            >backdrop-blur-md</code
          >) langsung disuntikkan secara instan.
        </p>
        <blockquote
          class="rounded-r-md border-l-2 border-sky-500 bg-sky-500/5 px-4 py-2 text-slate-300"
        >
          <strong>Tip Integrasi:</strong> Pada kode produksi di proyek asli, gunakan
          directive <code class="font-mono text-sky-400">@scroll.window</code> agar
          deteksi scroll mengikat penuh ke jendela browser utama, bukan ke internal
          container seperti pada contoh preview di atas.
        </blockquote>
      </article>
    </section>

    <!-- Tombol Kembali -->
    <footer class="mt-12 border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
      >
        ← Kembali ke Dashboard Sandbox
      </a>
    </footer>
  </main>
</Layout>

<!-- Pindahkan logic Alpine ke tag script terpisah biar aman dari compiler Astro -->
<script define:vars={{ codeSnippet }}>
  document.addEventListener('alpine:init', () => {
    Alpine.data('codeCopier', () => ({
      copied: false,
      codeText: codeSnippet,

      copy() {
        navigator.clipboard.writeText(this.codeText)
        this.copied = true
        setTimeout(() => {
          this.copied = false
        }, 2000)
      },
    }))
  })
</script>
