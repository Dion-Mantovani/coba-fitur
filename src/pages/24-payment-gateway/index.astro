---
// src/pages/24-payment-gateway/index.astro
export const prerender = false // Mode Server Dinamis (SSR)

import Layout from '../../layouts/Layout.astro'
import { supabase } from '../../utils/supabase'
import { Xendit } from 'xendit-node'

// 1. Inisialisasi SDK Xendit menggunakan Kunci Rahasia dari file .env
const secretKey = import.meta.env.XENDIT_SECRET_KEY
let xenditClient: any = null

if (secretKey) {
  xenditClient = new Xendit({ secretKey })
}

let errorMessage = ''

// 2. Logika Handle POST Form (Saat User Klik Beli Tiket)
if (Astro.request.method === 'POST') {
  try {
    if (!xenditClient) {
      throw new Error('Secret Key Xendit belum terkonfigurasi di server cloud!')
    }

    const formData = await Astro.request.formData()
    const customer_name = formData.get('customer_name')?.toString() || ''
    const customer_email = formData.get('customer_email')?.toString() || ''
    const ticket_type = formData.get('ticket_type')?.toString() || ''

    // Tentukan harga tiket secara dinamis berdasarkan kategori pilihan
    const amount = ticket_type === 'VIP' ? 500000 : 150000

    if (!customer_name || !customer_email || !ticket_type) {
      errorMessage = 'Waduh bro, semua data wajib diisi dulu ya!'
    } else {
      // Bikin ID unik string untuk acuan referensi Xendit (External ID)
      const externalId = `TICKET-EXP-${Date.now()}`

      // A. Kirim Sinyal ke Server Xendit untuk Membuat Link Invoice Resmi
      const invoice = await xenditClient.Invoice.createInvoice({
        data: {
          externalId: externalId,
          amount: amount,
          description: `Tiket Sandbox Dev Conf 2026 - Kategori ${ticket_type}`,
          customer: {
            givenNames: customer_name,
            email: customer_email,
          },
          // Setelah user bayar di Xendit, mereka akan dilempar balik otomatis ke URL sukses kita
          successRedirectUrl: `${Astro.url.origin}/24-payment-gateway/success?external_id=${externalId}`,
        },
      })

      if (invoice && invoice.invoiceUrl) {
        // B. Masukkan data dengan status awal 'PENDING' ke database Supabase kita
        const { error: dbError } = await supabase.from('event_tickets').insert([
          {
            external_id: externalId,
            customer_name,
            customer_email,
            ticket_type,
            amount,
            status: 'PENDING',
            payment_url: invoice.invoiceUrl,
          },
        ])

        if (dbError) {
          errorMessage = `Gagal simpan database lokal: ${dbError.message}`
        } else {
          // C. Jabat Tangan Sukses! Tendang user langsung masuk ke Gerbang Pembayaran Resmi Xendit
          return Astro.redirect(invoice.invoiceUrl)
        }
      } else {
        errorMessage = 'Gagal mendapatkan respon invoice dari gerbang Xendit.'
      }
    }
  } catch (e: any) {
    errorMessage = `Eror Integrasi Xendit: ${e.message}`
  }
}
---

<Layout title="24. Xendit Payment Gateway Integration">
  <main
    class="bg-slate-955 mx-auto min-h-screen max-w-4xl px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER TEMA CYBER CONFERENSI -->
    <header class="mb-10 space-y-3 text-center">
      <span
        class="inline-flex items-center gap-2 rounded-md border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 font-mono text-[10px] font-bold tracking-widest text-amber-400 uppercase"
      >
        🚀 FITUR 24: AUTOMATED FINANCIAL GATEWAY
      </span>
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
        Sandbox Developer Conference 2026
      </h1>
      <p class="mx-auto max-w-xl text-sm leading-relaxed text-slate-400">
        Beli tiket seminar teknologi lo secara instan melalui sistem integrasi
        otomatis gerbang pembayaran resmi Xendit Sandbox.
      </p>
    </header>

    {
      errorMessage && (
        <div class="mx-auto mb-6 max-w-lg rounded-xl border border-rose-500/30 bg-rose-500/10 p-4 font-mono text-xs text-rose-400">
          ⚠️ {errorMessage}
        </div>
      )
    }

    <!-- FORM PENJUALAN TIKET -->
    <div
      class="relative mx-auto max-w-lg overflow-hidden rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-xl md:p-8"
    >
      <div
        class="absolute top-0 right-0 left-0 h-1 bg-linear-to-r from-amber-500 to-orange-500"
      >
      </div>

      <h2
        class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3 font-mono text-base font-bold text-white"
      >
        🎟️ Formulir Registrasi Tiket
      </h2>

      <form method="POST" class="space-y-4 font-mono text-xs">
        <div>
          <label class="mb-1.5 block font-bold text-slate-400"
            >Nama Lengkap Anda</label
          >
          <input
            type="text"
            name="customer_name"
            required
            placeholder="Contoh: Dion Jaya"
            class="w-full rounded-lg border border-slate-800 bg-slate-950 p-2.5 text-sm text-white focus:border-amber-500 focus:outline-none"
          />
        </div>

        <div>
          <label class="mb-1.5 block font-bold text-slate-400"
            >Email Aktif (E-Ticket dikirim ke sini)</label
          >
          <input
            type="email"
            name="customer_email"
            required
            placeholder="dion@gmail.com"
            class="w-full rounded-lg border border-slate-800 bg-slate-950 p-2.5 text-sm text-white focus:border-amber-500 focus:outline-none"
          />
        </div>

        <div>
          <label class="mb-1.5 block font-bold text-slate-400"
            >Pilih Kategori Tiket</label
          >
          <div class="mt-1 grid grid-cols-2 gap-4">
            <label
              class="flex cursor-pointer flex-col rounded-xl border border-slate-800 bg-slate-950 p-3 transition-colors hover:border-amber-500/50"
            >
              <div class="flex items-center gap-2">
                <input
                  type="radio"
                  name="ticket_type"
                  value="REGULAR"
                  checked
                  class="accent-amber-500"
                />
                <span class="text-xs font-bold text-white">REGULAR</span>
              </div>
              <span class="mt-1 text-[11px] font-bold text-amber-400"
                >Rp 150.000</span
              >
            </label>

            <label
              class="flex cursor-pointer flex-col rounded-xl border border-slate-800 bg-slate-950 p-3 transition-colors hover:border-amber-500/50"
            >
              <div class="flex items-center gap-2">
                <input
                  type="radio"
                  name="ticket_type"
                  value="VIP"
                  class="accent-amber-500"
                />
                <span class="text-xs font-bold text-purple-400">VIP ACCESS</span
                >
              </div>
              <span class="mt-1 text-[11px] font-bold text-amber-400"
                >Rp 500.000</span
              >
            </label>
          </div>
        </div>

        <div class="pt-4">
          <button
            type="submit"
            class="w-full cursor-pointer rounded-xl bg-linear-to-r from-amber-600 to-amber-700 px-4 py-3.5 text-center text-sm font-bold tracking-wide text-white shadow-lg shadow-amber-950/30 transition-all hover:from-amber-700 hover:to-amber-800"
          >
            Checkout & Bayar via Xendit 💳
          </button>
        </div>
      </form>
    </div>
  </main>
</Layout>
