---
// src/pages/20-caching-webhook.astro
export const prerender = false

import Layout from '../layouts/Layout.astro'
import { supabase } from '../utils/supabase'
import { Redis } from '@upstash/redis'

// Matikan caching Vercel biar data diatur penuh oleh Redis
Astro.response.headers.set('Cache-Control', 'no-store, max-age=0')

const redis = new Redis({
  url:
    import.meta.env.UPSTASH_REDIS_REST_URL ||
    process.env.UPSTASH_REDIS_REST_URL ||
    '',
  token:
    import.meta.env.UPSTASH_REDIS_REST_TOKEN ||
    process.env.UPSTASH_REDIS_REST_TOKEN ||
    '',
})

let currentItems = []
let cacheStatus = 'CACHE HIT (Dari Redis) 🏎️'
let generatedAt = ''

// 1. Coba intip memori Redis dulu
const cachedData: any = await redis.get('supabase_items_cache')

if (cachedData) {
  // Jika data ada di Redis (Cache Hit)
  currentItems = cachedData.items
  generatedAt = cachedData.createdAt
} else {
  // Jika Redis kosong (Cache Miss), terpaksa ambil dari Supabase
  cacheStatus = 'CACHE MISS (Ambil Baru dari DB) 🔌'

  const { data } = await supabase
    .from('items')
    .select('*')
    .order('title', { ascending: true })

  currentItems = data || []
  generatedAt = new Date().toLocaleTimeString('id-ID', {
    timeZone: 'Asia/Jakarta',
  })

  // Simpan hasil masakannya ke Redis biar request berikutnya super cepat
  await redis.set(
    'supabase_items_cache',
    JSON.stringify({
      items: currentItems,
      createdAt: generatedAt,
    }),
  )
}

const isPromoValid = (item: any) => {
  if (!item.discount_price || !item.promo_ends_at) return false
  return new Date().getTime() < new Date(item.promo_ends_at).getTime()
}
---

<Layout title="20. Redis Caching Sandbox - Blueprint UI">
  <main
    class="bg-slate-955 mx-auto max-w-4xl px-4 py-12 font-sans text-slate-100"
  >
    <!-- HEADER -->
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-2 flex items-center gap-3">
        <span
          class="rounded-md border border-rose-500/30 bg-rose-500/10 px-2 py-0.5 font-mono text-[10px] font-bold text-rose-400"
          >20. REDIS CACHING</span
        >
        <h1 class="text-2xl font-bold tracking-tight text-white">
          Upstash Redis In-Memory Cache
        </h1>
      </div>
      <p class="text-sm leading-relaxed text-slate-400">
        Alternatif: Menggunakan In-Memory Caching (Redis). Webhook Supabase akan
        menghapus memori Redis secara instan tanpa hambatan Vercel CDN.
      </p>
    </header>

    <!-- STATUS INFO BANNER -->
    <section class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-800 bg-slate-900 p-4">
        <div class="mb-1 font-mono text-[10px] text-slate-500 uppercase">
          Stempel Waktu Data Dibuat
        </div>
        <div class="font-mono text-xl font-bold tracking-wide text-white">
          {generatedAt}
          <span class="text-xs text-slate-500">WIB</span>
        </div>
      </div>

      <div
        class="flex flex-col justify-center rounded-2xl border border-slate-800 bg-slate-900 p-4"
      >
        <div class="mb-1 font-mono text-[10px] text-slate-500 uppercase">
          Status Keaktifan Cache
        </div>
        <div
          class="flex items-center gap-2 rounded-lg border border-slate-900 bg-slate-950 px-3 py-1.5 font-mono text-xs font-bold text-emerald-400"
        >
          <span class="h-2 w-2 animate-ping rounded-full bg-emerald-500"></span>
          {cacheStatus}
        </div>
      </div>
    </section>

    <!-- LIVE STOREFRONT -->
    <section class="mb-12 space-y-4">
      <h2 class="text-xs font-semibold tracking-wider text-slate-400 uppercase">
        📦 Daftar Barang
      </h2>
      <div class="space-y-2">
        {
          currentItems?.map((item: any) => {
            const promoAktif = isPromoValid(item)
            return (
              <div class="flex items-center justify-between rounded-xl border border-slate-800 bg-slate-900 p-4">
                <div class="space-y-0.5">
                  <span class="font-mono text-[9px] text-slate-500 capitalize">
                    {item.category}
                  </span>
                  <div class="flex items-center gap-2">
                    <h3 class="text-xs font-bold text-white">{item.title}</h3>
                    {promoAktif && (
                      <span class="py-0.2 rounded border border-rose-500/20 bg-rose-500/10 px-1 font-mono text-[8px] font-bold tracking-wider text-rose-400 uppercase">
                        ⚡ FLASH LIVE
                      </span>
                    )}
                  </div>
                </div>
                <div class="text-right">
                  {promoAktif ? (
                    <div class="space-y-0.5">
                      <span class="font-mono text-[10px] text-slate-500 line-through">
                        {new Intl.NumberFormat('id-ID', {
                          style: 'currency',
                          currency: 'IDR',
                          maximumFractionDigits: 0,
                        }).format(item.price)}
                      </span>
                      <div class="font-mono text-xs font-bold text-rose-400">
                        {new Intl.NumberFormat('id-ID', {
                          style: 'currency',
                          currency: 'IDR',
                          maximumFractionDigits: 0,
                        }).format(item.discount_price)}
                      </div>
                    </div>
                  ) : (
                    <span class="font-mono text-xs font-bold text-emerald-400">
                      {new Intl.NumberFormat('id-ID', {
                        style: 'currency',
                        currency: 'IDR',
                        maximumFractionDigits: 0,
                      }).format(item.price)}
                    </span>
                  )}
                </div>
              </div>
            )
          })
        }
      </div>
    </section>

    <footer class="border-t border-slate-900 pt-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-slate-500 transition-colors hover:text-white"
        >← Kembali ke Dashboard Sandbox</a
      >
    </footer>
  </main>
</Layout>
